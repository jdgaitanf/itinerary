---
import Layout from "../components/layout/Layout.astro";
import NavBar from "../components/navigation/NavBar.astro";
import DayCard from "../components/itinerary/DayCard.astro";
import diaMock from "../data/dia-mock.json";
---

<Layout title="Itinerary - Wacken 2026">
  <div x-data="appState" x-init="init()" class="app-container" x-id="app">
    <main class="main-content">
      <!-- Vista Itinerario -->
      <div x-show="activeTab === 'itinerary'" class="tab-content">
        <div class="itinerary-list">
          <DayCard dia={diaMock} />
        </div>
      </div>

      <!-- Vista Finanzas -->
      <div x-show="activeTab === 'finances'" class="tab-content" x-cloak>
        <h2>Finanzas</h2>
        <p>Vista de finanzas - Próximamente</p>
      </div>

      <!-- Vista Ajustes -->
      <div x-show="activeTab === 'settings'" class="tab-content" x-cloak>
        <h2>Ajustes</h2>
        <p>Vista de ajustes - Próximamente</p>
      </div>
    </main>

    <!-- Barra de navegación -->
    <NavBar client:load />
  </div>

  <script>
    document.addEventListener("alpine:init", () => {
      Alpine.data("appState", () => ({
        activeTab: "itinerary",

        init() {
          const savedTab = localStorage.getItem("itinerary-active-tab");
          if (savedTab) {
            this.activeTab = savedTab;
          }
        },

        switchTab(tab) {
          this.activeTab = tab;
          localStorage.setItem("itinerary-active-tab", tab);
        },
      }));
    });
  </script>
</Layout>

<style>
  .app-container {
    display: flex;
    flex-direction: column;
    height: 100vh;
    max-height: 100vh;
    overflow: hidden;
  }

  .main-content {
    flex: 1;
    overflow-y: auto;
    padding-bottom: 70px;
  }

  .tab-content {
    padding: 16px;
  }

  .itinerary-list {
    max-width: 600px;
    margin: 0 auto;
  }

  [x-cloak] {
    display: none !important;
  }
</style>