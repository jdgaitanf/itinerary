---
import NodeList from "../components/NodeList.astro";
import "../styles/global.css";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes"
    />
    <meta name="theme-color" content="#f5f5f5" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content="black-translucent"
    />
    <title>Itinerario</title>
    <link rel="manifest" href="/itinerary/manifest.json" />
    <link rel="apple-touch-icon" href="/itinerary/icons/apple-touch-icon.png" />
    <link rel="icon" type="image/x-icon" href="/itinerary/icons/favicon.ico" />
    <link
      rel="icon"
      type="image/png"
      sizes="96x96"
      href="/itinerary/icons/favicon-96x96.png"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0,1"
    />
  </head>
  <body>
    <div id="app">
      <div id="app-header">
        <h1 id="app-title">Itinerario</h1>
        <label class="theme-toggle" id="theme-toggle-label">
          <input type="checkbox" id="theme-toggle-checkbox" />
          <span class="slider"></span>
        </label>
      </div>

      <!-- Contenedor de contenido según pestaña -->
      <div id="tabs-content">
        <div id="home-content" style="display: block;">
          <NodeList />
        </div>
        <div id="settings-content" style="display: none;">
          <div id="settings-panel">
            <h2>Ajustes</h2>
            <div id="settings-info">
              <p>
                <strong>Versión del viaje:</strong>
                <span id="viaje-version">Cargando...</span>
              </p>
              <p>
                <strong>Estado de la caché:</strong>
                <span id="cache-status">Cargando...</span>
              </p>
              <p><strong>Nodos:</strong> <span id="nodos-count">-</span></p>
              <p><strong>Aristas:</strong> <span id="aristas-count">-</span></p>
            </div>

            <div id="settings-advanced">
              <div id="settings-advanced-header">
                <h3>Ajustes Avanzados</h3>
                <span
                  class="material-symbols-outlined"
                  id="settings-advanced-toggle">expand_more</span
                >
              </div>
              <div id="settings-advanced-content" style="display: none;">
                <div id="settings-actions">
                  <h5>Cargar un nuevo grafo con itinerario</h5>
                  <div class="file-input-group">
                    <input type="file" id="graph-file-input" accept=".json" />
                    <button id="load-graph-btn">Cargar</button>
                  </div>
                  <div id="load-status"></div>

                  <div class="download-group">
                    <button id="download-def-btn"
                      >Descargar ItineraryDef.md</button
                    >
                  </div>
                  <button id="clear-cache-btn">Eliminar caché y recargar</button
                  >
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer con navegación -->
    <footer id="app-footer">
      <button data-tab="home" class="active">
        <span class="material-symbols-outlined">home</span>
        <span class="footer-label">Home</span>
      </button>
      <button data-tab="settings">
        <span class="material-symbols-outlined">settings</span>
        <span class="footer-label">Ajustes</span>
      </button>
    </footer>
  </body>

  <!-- Scripts -->
  <script>
    import "../scripts/index.js";
    import "../scripts/tabs.js";
    import "../scripts/settings.js";
    import "../scripts/theme.js";

    // Registrar Service Worker
    if ("serviceWorker" in navigator) {
      window.addEventListener("load", () => {
        navigator.serviceWorker
          .register("/itinerary/sw.js")
          .then((registration) => {
            console.log(
              "Service Worker registrado con éxito:",
              registration.scope,
            );
          })
          .catch((error) => {
            console.error("Error al registrar Service Worker:", error);
          });
      });
    }
  </script>
</html>
