---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Itinerary - Tu Viaje">
  <div 
    id="itinerario-view"
    x-data="{
      scrollPos: 0,
      viewName: 'itinerario',
      observer: null,
      loaderRef: null,
      init() {
        // Restaurar scroll si no ha pasado mucho tiempo
        const pos = $store.itinerary.obtenerScroll(this.viewName);
        if (pos > 0 && Date.now() - $store.itinerary.ultimaInteraccion < $store.itinerary.TIMEOUT_SCROLL) {
          setTimeout(() => {
            const el = document.getElementById('itinerario-view');
            if (el) el.scrollTop = pos;
          }, 100);
        }
        
        // Configurar IntersectionObserver para scroll infinito
        this.observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting && !$store.itinerary.todosLosDiasCargados) {
              console.log('🔄 Cargando más días...');
              $store.itinerary.cargarMasDias();
            }
          });
        }, { rootMargin: '200px' });
        
        // Observar el elemento de carga cuando cambien los días cargados
        this.$watch('$store.itinerary.diasCargados.length', () => {
          this.$nextTick(() => {
            this.loaderRef = document.getElementById('loading-more');
            if (this.loaderRef) {
              console.log('👀 Observando loading-more (reconectado)');
              this.observer.observe(this.loaderRef);
            }
          });
        });
        
        // Observar inicialmente
        this.$nextTick(() => {
          this.loaderRef = document.getElementById('loading-more');
          if (this.loaderRef) {
            console.log('👀 Observando loading-more (inicial)');
            this.observer.observe(this.loaderRef);
          } else {
            console.log('ℹ️ No se encontró loading-more inicial');
          }
        });
      }
    }"
    x-init="init()"
    @scroll.debounce="
      const el = document.getElementById('itinerario-view');
      if (el) {
        $store.itinerary.guardarScroll(viewName, el.scrollTop);
      }
    "
    style="overflow-y: auto; max-height: 100vh; padding-bottom: 80px;"
  >
    <!-- Header -->
    <header class="py-4 px-2 sticky top-0 bg-opacity-95 z-10" style="background: var(--color-bg); backdrop-filter: blur(8px);">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-xl font-bold" style="color: var(--color-text-primary);">
            <span class="material-symbols-rounded text-2xl align-middle mr-2" style="color: var(--color-primary);">luggage</span>
            <span x-text="$store.itinerary.dias.length > 0 ? 'Mi Viaje' : 'Cargando...'"></span>
          </h1>
          <p class="text-sm" style="color: var(--color-text-secondary);" x-show="$store.itinerary.dias.length > 0">
            <span x-text="`${$store.itinerary.dias.length} días · ${$store.itinerary.diasCargados.length} cargados`"></span>
            <span x-show="$store.itinerary.cargando" class="ml-2 inline-block">
              <span class="material-symbols-rounded animate-spin text-sm">progress_activity</span>
            </span>
          </p>
        </div>
        <!-- Indicador de caché -->
        <div x-data="{ cacheInfo: null }" x-init="cacheInfo = $store.itinerary.getCacheInfo()">
          <span 
            x-show="cacheInfo?.existe"
            class="text-xs px-2 py-1 rounded-full"
            :style="`background: ${cacheInfo?.esValida ? 'rgba(46, 204, 113, 0.2)' : 'rgba(231, 76, 60, 0.2)'}; color: ${cacheInfo?.esValida ? '#2ECC71' : '#E74C3C'};`"
          >
            <span class="material-symbols-rounded text-sm align-middle" x-text="cacheInfo?.esValida ? 'check_circle' : 'warning'"></span>
            <span x-text="cacheInfo?.esValida ? 'Caché' : 'Sin caché'"></span>
          </span>
        </div>
      </div>
    </header>
    
    <!-- Loading inicial -->
    <div x-show="$store.itinerary.diasCargados.length === 0" class="empty-state">
      <span class="material-symbols-rounded" style="font-size: 48px; opacity: 0.5;">schedule</span>
      <p class="mt-4">Cargando tu itinerario...</p>
      <p class="text-xs mt-2" style="color: var(--color-text-muted);">Esto puede tomar unos segundos en la primera carga</p>
    </div>
    
    <!-- Días -->
    <template x-for="(dia, index) in $store.itinerary.diasCargados" :key="dia.fecha">
      <div class="dia-card" x-data="{ expandido: true }">
        <!-- Header del día -->
        <div 
          class="dia-card-header"
          @click="expandido = !expandido"
        >
          <div>
            <h2 class="font-semibold text-base" style="color: var(--color-text-primary);">
              <span class="material-symbols-rounded text-lg align-middle mr-1" style="color: var(--color-primary);">calendar_today</span>
              <span>Día <span x-text="dia.numeroDia || '?'"></span></span>
              <span class="text-sm font-normal" style="color: var(--color-text-secondary);">
                · <span x-text="dia.fecha ? new Date(dia.fecha).toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' }) : 'Fecha no especificada'"></span>
              </span>
            </h2>
            <div class="flex items-center gap-2 mt-1">
              <span class="text-sm" style="color: var(--color-text-secondary);">
                <span class="material-symbols-rounded text-sm align-middle">location_on</span>
                <span x-text="dia.ciudad || 'Ciudad no especificada'"></span>
              </span>
              <template x-if="dia.clima">
                <span class="text-sm" style="color: var(--color-text-secondary);">
                  <span class="material-symbols-rounded text-sm align-middle">wb_sunny</span>
                  <span x-text="dia.clima.temperatura ? `${dia.clima.temperatura}°C` : ''"></span>
                  <span x-text="dia.clima.condiciones ? ` · ${dia.clima.condiciones}` : ''"></span>
                </span>
              </template>
            </div>
          </div>
          <div>
            <span 
              class="material-symbols-rounded text-xl transition-transform duration-200"
              :style="`transform: rotate(${expandido ? '180deg' : '0deg'});`"
            >
              expand_more
            </span>
          </div>
        </div>
        
        <!-- Content del día -->
        <div 
          class="dia-card-content"
          x-show="expandido"
          x-collapse.duration.200ms
        >
          <template x-if="dia.eventos && dia.eventos.length > 0">
            <template x-for="(evento, idx) in dia.eventos" :key="evento.id">
              <div>
                <div 
                  class="evento-item"
                  :class="{
                    'expandido': $store.itinerary.estaExpandido(index, evento.id),
                    [$store.itinerary.getEventColor(evento.tipo)]: true
                  }"
                  @click="$store.itinerary.toggleEvento(index, evento.id)"
                >
                  <!-- Contenido del evento -->
                  <div class="flex items-start gap-3">
                    <!-- Ícono -->
                    <span 
                      class="material-symbols-rounded text-xl flex-shrink-0"
                      :style="`color: var(--event-color, var(--color-primary)); margin-top: 1px;`"
                      x-text="$store.itinerary.getEventIcon(evento.tipo) || 'help'"
                    ></span>
                    
                    <!-- Info principal -->
                    <div class="flex-1 min-w-0">
                      <div class="flex items-start justify-between gap-2">
                        <span class="text-sm font-medium truncate" style="color: var(--color-text-primary);" x-text="evento.displayName || evento.nombre"></span>
                        <template x-if="evento.displayTime">
                          <span class="text-xs font-medium flex-shrink-0" style="color: var(--color-text-secondary);" x-text="evento.displayTime"></span>
                        </template>
                      </div>
                      
                      <!-- Subtipo o detalle adicional -->
                      <template x-if="evento.tipo === 'vuelo' && evento.nodo?.codigo_iata">
                        <div class="text-xs" style="color: var(--color-text-muted);">
                          <span class="material-symbols-rounded text-xs align-middle">flight_takeoff</span>
                          <span x-text="evento.nodo.codigo_iata"></span>
                          <template x-if="evento.aristaSalida?.transporte?.numero_vuelo">
                            <span> · Vuelo <span x-text="evento.aristaSalida.transporte.numero_vuelo"></span></span>
                          </template>
                        </div>
                      </template>
                      
                      <template x-if="evento.tipo === 'hotel'">
                        <div class="text-xs" style="color: var(--color-text-muted);">
                          <span class="material-symbols-rounded text-xs align-middle">bed</span>
                          <span x-text="evento.nodo.direccion?.ciudad || ''"></span>
                          <template x-if="evento.nodo.reserva?.codigo_reserva">
                            <span> · Reserva: <span x-text="evento.nodo.reserva.codigo_reserva"></span></span>
                          </template>
                        </div>
                      </template>
                      
                      <!-- Holgura -->
                      <template x-if="evento.holgura">
                        <div class="text-xs mt-1 flex items-center gap-1" style="color: #E74C3C;">
                          <span class="material-symbols-rounded text-sm">warning</span>
                          <span>⚠️ Salir <span x-text="evento.holgura.tiempoRequerido"></span> antes (<span x-text="evento.holgura.horaSalidaRecomendada"></span>)</span>
                        </div>
                      </template>
                      
                      <!-- Dirección resumida -->
                      <template x-if="evento.direccion && evento.tipo !== 'vuelo'">
                        <div class="text-xs mt-1 flex items-center gap-1" style="color: var(--color-text-muted);">
                          <span class="material-symbols-rounded text-sm">location_on</span>
                          <span class="truncate" x-text="evento.direccion"></span>
                        </div>
                      </template>
                    </div>
                    
                    <!-- Indicador de expansión -->
                    <span 
                      class="material-symbols-rounded text-lg flex-shrink-0 transition-transform duration-200"
                      :style="`transform: rotate(${$store.itinerary.estaExpandido(index, evento.id) ? '180deg' : '0deg'});`"
                      style="color: var(--color-text-muted);"
                    >
                      expand_more
                    </span>
                  </div>
                </div>
                
                <!-- Detalle expandido -->
                <div 
                  x-show="$store.itinerary.estaExpandido(index, evento.id)"
                  x-collapse.duration.250ms
                >
                  <div class="evento-detalle" :class="[$store.itinerary.getEventColor(evento.tipo)]">
                    <!-- Título -->
                    <div class="flex items-start justify-between pt-1">
                      <div>
                        <h3 class="text-base font-semibold" style="color: var(--color-text-primary);">
                          <span 
                            class="material-symbols-rounded text-xl align-middle mr-1"
                            :style="`color: var(--event-color, var(--color-primary));`"
                            x-text="$store.itinerary.getEventIcon(evento.tipo) || 'help'"
                          ></span>
                          <span x-text="evento.nombre"></span>
                        </h3>
                        <template x-if="evento.detalles?.fecha">
                          <p class="text-sm mt-1" style="color: var(--color-text-secondary);">
                            <span class="material-symbols-rounded text-sm align-middle">event</span>
                            <span x-text="new Date(evento.detalles.fecha).toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' })"></span>
                            <template x-if="evento.detalles.horaInicio">
                              <span> · <span x-text="evento.detalles.horaInicio"></span></span>
                            </template>
                            <template x-if="evento.detalles.horaFin">
                              <span> - <span x-text="evento.detalles.horaFin"></span></span>
                            </template>
                          </p>
                        </template>
                      </div>
                      <button 
                        @click="$store.itinerary.toggleEvento(index, evento.id)"
                        class="text-sm p-1 hover:opacity-70 transition-opacity"
                        style="color: var(--color-text-muted);"
                        aria-label="Cerrar detalles"
                      >
                        <span class="material-symbols-rounded">close</span>
                      </button>
                    </div>
                    
                    <div class="divider"></div>
                    
                    <!-- Detalles específicos -->
                    <div class="space-y-2 text-sm">
                      <!-- Vuelo -->
                      <template x-if="evento.tipo === 'vuelo'">
                        <div class="grid grid-cols-2 gap-1">
                          <div>
                            <span class="text-xs" style="color: var(--color-text-muted);">Aerolínea</span>
                            <p style="color: var(--color-text-primary);" x-text="evento.detalles?.aerolinea || 'No especificada'"></p>
                          </div>
                          <div>
                            <span class="text-xs" style="color: var(--color-text-muted);">Número de vuelo</span>
                            <p style="color: var(--color-text-primary);" x-text="evento.detalles?.numeroVuelo || 'N/A'"></p>
                          </div>
                          <div>
                            <span class="text-xs" style="color: var(--color-text-muted);">Terminal</span>
                            <p style="color: var(--color-text-primary);" x-text="evento.detalles?.terminal || 'N/A'"></p>
                          </div>
                          <div>
                            <span class="text-xs" style="color: var(--color-text-muted);">Puerta</span>
                            <p style="color: var(--color-text-primary);" x-text="evento.detalles?.puerta || 'N/A'"></p>
                          </div>
                          <template x-if="evento.detalles?.codigoReserva">
                            <div class="col-span-2">
                              <span class="text-xs" style="color: var(--color-text-muted);">Código de reserva</span>
                              <p style="color: var(--color-text-primary);" class="font-mono" x-text="evento.detalles.codigoReserva"></p>
                            </div>
                          </template>
                        </div>
                      </template>
                      
                      <!-- Hotel -->
                      <template x-if="evento.tipo === 'hotel'">
                        <div>
                          <template x-if="evento.detalles?.checkIn">
                            <div class="flex justify-between">
                              <span class="text-xs" style="color: var(--color-text-muted);">Check-in</span>
                              <span style="color: var(--color-text-primary);" x-text="evento.detalles.checkIn"></span>
                            </div>
                          </template>
                          <template x-if="evento.detalles?.checkOut">
                            <div class="flex justify-between">
                              <span class="text-xs" style="color: var(--color-text-muted);">Check-out</span>
                              <span style="color: var(--color-text-primary);" x-text="evento.detalles.checkOut"></span>
                            </div>
                          </template>
                          <template x-if="evento.detalles?.titular">
                            <div class="flex justify-between">
                              <span class="text-xs" style="color: var(--color-text-muted);">Titular</span>
                              <span style="color: var(--color-text-primary);" x-text="evento.detalles.titular"></span>
                            </div>
                          </template>
                          <template x-if="evento.detalles?.plataforma">
                            <div class="flex justify-between">
                              <span class="text-xs" style="color: var(--color-text-muted);">Plataforma</span>
                              <span style="color: var(--color-text-primary);" x-text="evento.detalles.plataforma"></span>
                            </div>
                          </template>
                        </div>
                      </template>
                      
                      <!-- Festival -->
                      <template x-if="evento.tipo === 'festival'">
                        <div>
                          <template x-if="evento.detalles?.apertura">
                            <div class="flex justify-between">
                              <span class="text-xs" style="color: var(--color-text-muted);">Apertura</span>
                              <span style="color: var(--color-text-primary);" x-text="evento.detalles.apertura"></span>
                            </div>
                          </template>
                          <template x-if="evento.detalles?.cierre">
                            <div class="flex justify-between">
                              <span class="text-xs" style="color: var(--color-text-muted);">Cierre</span>
                              <span style="color: var(--color-text-primary);" x-text="evento.detalles.cierre"></span>
                            </div>
                          </template>
                          <template x-if="evento.detalles?.lineup && evento.detalles.lineup.length > 0">
                            <div>
                              <span class="text-xs" style="color: var(--color-text-muted);">Lineup</span>
                              <p style="color: var(--color-text-primary);" x-text="evento.detalles.lineup.join(' · ')"></p>
                            </div>
                          </template>
                        </div>
                      </template>
                      
                      <!-- Actividad -->
                      <template x-if="evento.tipo === 'actividad'">
                        <div>
                          <template x-if="evento.detalles?.duracion">
                            <div class="flex justify-between">
                              <span class="text-xs" style="color: var(--color-text-muted);">Duración estimada</span>
                              <span style="color: var(--color-text-primary);" x-text="evento.detalles.duracion"></span>
                            </div>
                          </template>
                          <template x-if="evento.detalles?.horarioRecomendado">
                            <div class="flex justify-between">
                              <span class="text-xs" style="color: var(--color-text-muted);">Horario recomendado</span>
                              <span style="color: var(--color-text-primary);" x-text="evento.detalles.horarioRecomendado"></span>
                            </div>
                          </template>
                          <template x-if="evento.detalles?.urlOficial">
                            <div>
                              <a 
                                :href="evento.detalles.urlOficial"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-sm underline hover:opacity-70 transition-opacity"
                                style="color: var(--color-primary);"
                              >
                                <span class="material-symbols-rounded text-sm align-middle">link</span>
                                Sitio web oficial
                              </a>
                            </div>
                          </template>
                        </div>
                      </template>
                      
                      <!-- Actividades dentro del nodo -->
                      <template x-if="evento.detalles?.actividades && evento.detalles.actividades.length > 0">
                        <div>
                          <span class="text-xs" style="color: var(--color-text-muted);">Actividades planificadas</span>
                          <ul class="mt-1 space-y-1">
                            <template x-for="act in evento.detalles.actividades" :key="act.id">
                              <li class="text-sm flex items-start gap-2" style="color: var(--color-text-primary);">
                                <span class="material-symbols-rounded text-sm" style="color: var(--color-text-muted);">check_circle</span>
                                <span>
                                  <span x-text="act.nombre"></span>
                                  <template x-if="act.duracion_estimada">
                                    <span class="text-xs block" style="color: var(--color-text-muted);" x-text="act.duracion_estimada"></span>
                                  </template>
                                  <template x-if="act.reserva?.fecha_reservada">
                                    <span class="text-xs block" style="color: var(--color-text-muted);">
                                      Reservado: <span x-text="new Date(act.reserva.fecha_reservada).toLocaleDateString('es-ES')"></span>
                                      <template x-if="act.reserva.hora_reservada">
                                        <span> a las <span x-text="act.reserva.hora_reservada"></span></span>
                                      </template>
                                    </span>
                                  </template>
                                </span>
                              </li>
                            </template>
                          </ul>
                        </div>
                      </template>
                      
                      <!-- Transporte -->
                      <template x-if="evento.aristaSalida">
                        <div>
                          <span class="text-xs" style="color: var(--color-text-muted);">Transporte</span>
                          <div class="flex items-center gap-2 mt-1">
                            <span 
                              class="material-symbols-rounded"
                              :style="`color: var(--event-color, var(--color-primary));`"
                              x-text="$store.itinerary.getEventIcon(evento.tipo) || 'help'"
                            ></span>
                            <span style="color: var(--color-text-primary);">
                              <span x-text="evento.aristaSalida.modo"></span>
                              <template x-if="evento.aristaSalida.transporte?.compania">
                                <span> · <span x-text="evento.aristaSalida.transporte.compania"></span></span>
                              </template>
                            </span>
                          </div>
                          <template x-if="evento.aristaSalida.tiempo_estimado">
                            <div class="text-xs" style="color: var(--color-text-secondary);">
                              <span class="material-symbols-rounded text-xs align-middle">schedule</span>
                              <span x-text="evento.aristaSalida.tiempo_estimado.minutos"></span> min
                              <template x-if="evento.aristaSalida.tiempo_estimado.rango">
                                <span> (aprox. <span x-text="evento.aristaSalida.tiempo_estimado.rango"></span> min)</span>
                              </template>
                            </div>
                          </template>
                        </div>
                      </template>
                    </div>
                    
                    <!-- Dirección -->
                    <template x-if="evento.direccion">
                      <div class="mt-3">
                        <span class="text-xs" style="color: var(--color-text-muted);">Dirección</span>
                        <p class="text-sm mt-1" style="color: var(--color-text-primary);" x-text="evento.direccion"></p>
                        <template x-if="evento.mapsLink">
                          <a 
                            :href="evento.mapsLink"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="maps-link mt-1 inline-flex"
                          >
                            <span class="material-symbols-rounded text-sm">map</span>
                            Ver en Google Maps
                          </a>
                        </template>
                      </div>
                    </template>
                    
                    <!-- Costos -->
                    <template x-if="evento.costo">
                      <div class="mt-3 pt-2 border-t" style="border-color: var(--color-border-light);">
                        <span class="text-xs" style="color: var(--color-text-muted);">Costo</span>
                        <div class="flex items-center justify-between mt-1">
                          <span style="color: var(--color-text-primary);">
                            <span x-text="$store.itinerary.formatearMonto(evento.costo.valor, evento.costo.moneda)"></span>
                            <template x-if="evento.costo.moneda">
                              <span class="text-xs" style="color: var(--color-text-muted);"> (<span x-text="evento.costo.moneda"></span>)</span>
                            </template>
                          </span>
                          <span class="text-xs" style="color: var(--color-text-secondary);">
                            <template x-if="evento.costo.pagado_por">
                              <span>✅ Pagado por <span x-text="evento.costo.pagado_por"></span></span>
                            </template>
                            <template x-if="!evento.costo.pagado_por">
                              <span>⏳ Pendiente de pago</span>
                            </template>
                            <template x-if="evento.costo.incluido_en">
                              <span class="block text-xs" style="color: var(--color-text-muted);">Incluido en: <span x-text="evento.costo.incluido_en"></span></span>
                            </template>
                          </span>
                        </div>
                      </div>
                    </template>
                    
                    <!-- Notas -->
                    <template x-if="evento.detalles?.notas">
                      <div class="mt-3 pt-2 border-t" style="border-color: var(--color-border-light);">
                        <span class="text-xs" style="color: var(--color-text-muted);">Notas</span>
                        <p class="text-sm mt-1" style="color: var(--color-text-secondary);" x-text="evento.detalles.notas"></p>
                      </div>
                    </template>
                  </div>
                </div>
              </div>
            </template>
          </template>
          <template x-if="!dia.eventos || dia.eventos.length === 0">
            <div class="text-center py-4 text-sm" style="color: var(--color-text-muted);">
              <span class="material-symbols-rounded">event_busy</span>
              <p>No hay eventos programados para este día</p>
            </div>
          </template>
        </div>
      </div>
    </template>
    
    <!-- Loading more - siempre visible si hay más días por cargar -->
    <div 
      id="loading-more"
      x-show="$store.itinerary.hayMasDias"
      class="loading-more"
    >
      <span x-show="$store.itinerary.cargando" class="flex items-center justify-center gap-2">
        <span class="material-symbols-rounded animate-spin">progress_activity</span>
        Cargando más días...
      </span>
      <span x-show="!$store.itinerary.cargando && $store.itinerary.hayMasDias" class="text-sm">
        <span class="material-symbols-rounded inline-block">expand_more</span>
        Desplázate para cargar más
      </span>
    </div>
    
    <!-- Fin del viaje -->
    <div 
      x-show="$store.itinerary.todosLosDiasCargados && $store.itinerary.diasCargados.length > 0"
      class="text-center py-8"
    >
      <span class="material-symbols-rounded" style="font-size: 32px; color: var(--color-text-muted);">celebration</span>
      <p class="text-sm mt-2" style="color: var(--color-text-secondary);">¡Fin del viaje!</p>
      <p class="text-xs" style="color: var(--color-text-muted);" x-text="`${$store.itinerary.diasCargados.length} días de aventura`"></p>
    </div>
  </div>
</Layout>