---
import Layout from "../components/layout/Layout.astro";
import NavBar from "../components/navigation/NavBar.astro";
import DayCard from "../components/itinerary/DayCard.astro";
import { loadViajeData } from "../scripts/dataLoader";
import { buildItineraryFromGraph } from "../scripts/graphBuilder";

// Cargar datos en el servidor (Astro)
const viajeData = await loadViajeData();

// Construir el itinerario
let eventos = [];
let nombreViaje = "Wacken 2026";
let fechasViaje = { inicio: "", fin: "" };

if (viajeData) {
  nombreViaje = viajeData.nombre_viaje;
  fechasViaje = viajeData.fechas;
  eventos = buildItineraryFromGraph(viajeData.nodos, viajeData.aristas);
}

// Crear un día único con todos los eventos (para pruebas)
const diaUnico = {
  dia: 1,
  fecha: fechasViaje.inicio || "2026-07-17",
  ciudad: "Recorrido del grafo",
  clima: {
    temperatura: "",
    condicion: "Todos los eventos",
    icono: "route"
  },
  eventos: eventos
};
---

<Layout title={`Itinerary - ${nombreViaje}`}>
  <div x-data="appState" x-init="init()" class="app-container" x-id="app">
    <main class="main-content">
      <!-- Vista Itinerario -->
      <div x-show="activeTab === 'itinerary'" class="tab-content">
        <div class="itinerary-list">
          {eventos.length > 0 ? (
            <DayCard dia={diaUnico} />
          ) : (
            <p>No se encontraron eventos. Verifica que los archivos JSON estén disponibles.</p>
          )}
          <p style="font-size: 12px; color: #888; margin-top: 16px; text-align: center;">
            Total de eventos: {eventos.length}
          </p>
        </div>
      </div>

      <!-- Vista Finanzas -->
      <div x-show="activeTab === 'finances'" class="tab-content" x-cloak>
        <h2>Finanzas</h2>
        <p>Vista de finanzas - Próximamente</p>
      </div>

      <!-- Vista Ajustes -->
      <div x-show="activeTab === 'settings'" class="tab-content" x-cloak>
        <h2>Ajustes</h2>
        <p>Vista de ajustes - Próximamente</p>
      </div>
    </main>

    <!-- Barra de navegación -->
    <NavBar client:load />
  </div>

  <script>
    document.addEventListener("alpine:init", () => {
      Alpine.data("appState", () => ({
        activeTab: "itinerary",

        init() {
          const savedTab = localStorage.getItem("itinerary-active-tab");
          if (savedTab) {
            this.activeTab = savedTab;
          }
        },

        switchTab(tab) {
          this.activeTab = tab;
          localStorage.setItem("itinerary-active-tab", tab);
        },
      }));
    });
  </script>
</Layout>

<style>
  .app-container {
    display: flex;
    flex-direction: column;
    height: 100vh;
    max-height: 100vh;
    overflow: hidden;
  }

  .main-content {
    flex: 1;
    overflow-y: auto;
    padding-bottom: 70px;
  }

  .tab-content {
    padding: 16px;
  }

  .itinerary-list {
    max-width: 600px;
    margin: 0 auto;
  }

  [x-cloak] {
    display: none !important;
  }
</style>