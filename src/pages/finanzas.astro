---
// src/pages/finanzas.astro
import Layout from '../layouts/Layout.astro';
import FinanzasResumen from '../components/FinanzasResumen.astro';
import ListaGastos from '../components/ListaGastos.astro';
---

<Layout title="Itinerary - Finanzas">
  <div 
    id="finanzas-view"
    x-data="{
      scrollPos: 0,
      viewName: 'finanzas',
      verTodosLosGastos: false,
      finanzas: null,
      init() {
        // Restaurar scroll
        const pos = $store.itinerary.obtenerScroll(this.viewName);
        if (pos > 0 && Date.now() - $store.itinerary.ultimaInteraccion < $store.itinerary.TIMEOUT_SCROLL) {
          setTimeout(() => {
            const el = document.getElementById('finanzas-view');
            if (el) el.scrollTop = pos;
          }, 100);
        }
        this.finanzas = $store.itinerary.getFinanzas();
      }
    }"
    x-init="init()"
    @scroll.debounce="
      const el = document.getElementById('finanzas-view');
      if (el) {
        $store.itinerary.guardarScroll(viewName, el.scrollTop);
      }
    "
    style="overflow-y: auto; max-height: 100vh; padding-bottom: 80px;"
  >
    <!-- Header -->
    <header class="py-4 px-2 sticky top-0 z-10" style="background: var(--color-bg); backdrop-filter: blur(8px);">
      <h1 class="text-xl font-bold" style="color: var(--color-text-primary);">
        <span class="material-symbols-rounded text-2xl align-middle mr-2" style="color: var(--color-primary);">payments</span>
        Finanzas
      </h1>
      <p class="text-sm" style="color: var(--color-text-secondary);">
        Resumen financiero del viaje
      </p>
    </header>

    <!-- Contenido -->
    <div>
      <!-- Resumen ejecutivo -->
      <FinanzasResumen 
        :finanzas="finanzas"
        :moneda="$store.itinerary.moneda"
      />

      <!-- Selector de moneda -->
      <div class="mt-4">
        <label class="text-sm font-medium" style="color: var(--color-text-secondary);">
          Moneda de visualización
        </label>
        <div class="moneda-selector mt-2">
          <button 
            @click="$store.itinerary.cambiarMoneda('COP')"
            :class="{ 'active': $store.itinerary.moneda === 'COP' }"
          >
            COP $
          </button>
          <button 
            @click="$store.itinerary.cambiarMoneda('EUR')"
            :class="{ 'active': $store.itinerary.moneda === 'EUR' }"
          >
            EUR €
          </button>
          <button 
            @click="$store.itinerary.cambiarMoneda('USD')"
            :class="{ 'active': $store.itinerary.moneda === 'USD' }"
          >
            USD $
          </button>
          <button 
            @click="$store.itinerary.cambiarMoneda('CHF')"
            :class="{ 'active': $store.itinerary.moneda === 'CHF' }"
          >
            CHF
          </button>
        </div>
      </div>

      <!-- Botón para ver todos los gastos -->
      <div class="mt-4">
        <button 
          @click="verTodosLosGastos = !verTodosLosGastos"
          class="w-full py-3 px-4 rounded-xl font-medium text-sm transition-all flex items-center justify-between"
          style="background: var(--color-card-bg); color: var(--color-text-primary);"
        >
          <span>
            <span class="material-symbols-rounded text-lg align-middle mr-2">receipt_long</span>
            <span x-text="verTodosLosGastos ? 'Ocultar lista de gastos' : 'Ver todos los gastos'"></span>
          </span>
          <span 
            class="material-symbols-rounded transition-transform duration-200"
            :style="`transform: rotate(${verTodosLosGastos ? '180deg' : '0deg'});`"
          >
            expand_more
          </span>
        </button>
      </div>

      <!-- Lista de gastos -->
      <div x-show="verTodosLosGastos" x-collapse.duration.300ms>
        <ListaGastos 
          :gastos="finanzas?.gastos || []"
          :moneda="$store.itinerary.moneda"
        />
      </div>
    </div>
  </div>
</Layout>