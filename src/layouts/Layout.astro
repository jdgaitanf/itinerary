---
// src/layouts/Layout.astro
import '../styles/global.css';
import '../styles/themes.css';

export interface Props {
  title?: string;
  description?: string;
}

const { title = 'Itinerary', description = 'Tu itinerario de viaje personal' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es" data-theme="claro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=1.0, user-scalable=yes" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Material Symbols CDN -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0,1&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Preconnect para mejorar rendimiento -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  
  <body x-data="{}" x-init="$store.itinerary?.init()" @load="$store.itinerary?._aplicarTema()">
    <div id="app" class="app-container">
      <slot />
    </div>
    
       <!-- Bottom Navigation -->
    <nav class="bottom-nav" x-data="{
      active: $store.itinerary?.vistaActiva || 'itinerario',
      init() {
        this.$watch('$store.itinerary.vistaActiva', (value) => {
          this.active = value;
        });
      }
    }" x-init="init()">
      <button 
        @click="$store.itinerary?.cambiarVista('itinerario'); window.location.href = '/'"
        :class="{ 'active': active === 'itinerario' }"
        aria-label="Itinerario"
      >
        <span class="material-symbols-rounded">calendar_month</span>
        <span>Itinerario</span>
      </button>
      
      <button 
        @click="$store.itinerary?.cambiarVista('finanzas'); window.location.href = '/finanzas'"
        :class="{ 'active': active === 'finanzas' }"
        aria-label="Finanzas"
      >
        <span class="material-symbols-rounded">payments</span>
        <span>Finanzas</span>
      </button>
      
      <button 
        @click="$store.itinerary?.cambiarVista('ajustes'); window.location.href = '/ajustes'"
        :class="{ 'active': active === 'ajustes' }"
        aria-label="Ajustes"
      >
        <span class="material-symbols-rounded">settings</span>
        <span>Ajustes</span>
      </button>
    </nav>
    
    <!-- Script para registrar el store (con Alpine incluido) -->
    <script type="module" src="/src/scripts/alpine-store.js"></script>
  </body>
</html>