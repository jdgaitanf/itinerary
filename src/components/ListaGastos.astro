---
// src/components/ListaGastos.astro
export interface Props {
  gastos: any[];
  moneda: string;
}

const { gastos, moneda } = Astro.props;
---

<div x-data="{
  gastos: [],
  moneda: '',
  expandedGastos: {},
  init() {
    this.gastos = gastos;
    this.moneda = moneda;
  },
  toggleGasto(id) {
    if (this.expandedGastos[id]) {
      delete this.expandedGastos[id];
    } else {
      this.expandedGastos[id] = true;
    }
    this.expandedGastos = { ...this.expandedGastos };
  },
  isExpanded(id) {
    return !!this.expandedGastos[id];
  },
  getIcon(tipo) {
    const icons = {
      vuelo: 'flight',
      hotel: 'bed',
      actividad: 'theater_comedy',
      transporte: 'directions_car',
      festival: 'music_note',
      comida: 'restaurant',
      casa: 'home',
    };
    return icons[tipo] || 'receipt';
  },
  getColor(tipo) {
    const colors = {
      vuelo: '#4A6CF7',
      hotel: '#2ECC71',
      actividad: '#F39C12',
      transporte: '#9B59B6',
      festival: '#E74C3C',
      comida: '#E67E22',
      casa: '#3498DB',
    };
    return colors[tipo] || '#666666';
  }
}">
  <!-- Totales -->
  <div class="mt-4 p-4 rounded-xl flex justify-between items-center" style="background: var(--color-card-bg);">
    <div>
      <span class="text-sm" style="color: var(--color-text-secondary);">Total gastos</span>
      <p class="text-lg font-bold" style="color: var(--color-text-primary);">
        {$store.itinerary.formatearMonto(
          gastos.reduce((sum, g) => sum + g.monto, 0),
          'COP'
        )}
      </p>
    </div>
    <div class="text-right">
      <span class="text-sm" style="color: var(--color-text-secondary);">Gastos pendientes</span>
      <p class="text-lg font-bold" style="color: #E74C3C;">
        {$store.itinerary.formatearMonto(
          gastos.filter(g => !g.pagadoPor).reduce((sum, g) => sum + g.monto, 0),
          'COP'
        )}
      </p>
    </div>
  </div>

  <!-- Lista -->
  <div class="mt-4 space-y-2">
    <template x-for="gasto in gastos" :key="gasto.id">
      <div>
        <div 
          class="p-3 rounded-xl cursor-pointer transition-all"
          style="background: var(--color-card-bg);"
          @click="toggleGasto(gasto.id)"
        >
          <div class="flex items-center gap-3">
            <!-- Icono -->
            <span 
              class="material-symbols-rounded"
              :style="`color: ${getColor(gasto.tipo)};`"
            >
              <span x-html="getIcon(gasto.tipo)"></span>
            </span>
            
            <!-- Info -->
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-2">
                <span class="text-sm font-medium truncate" style="color: var(--color-text-primary);">
                  {gasto.nombre}
                </span>
                <span class="text-sm font-medium flex-shrink-0" style="color: var(--color-text-primary);">
                  {$store.itinerary.formatearMonto(gasto.monto, gasto.moneda)}
                </span>
              </div>
              <div class="flex items-center gap-2 text-xs" style="color: var(--color-text-muted);">
                <span>{gasto.fecha}</span>
                <span>·</span>
                <span>
                  {gasto.pagadoPor ? (
                    <span style="color: #2ECC71;">✅ {gasto.pagadoPor}</span>
                  ) : (
                    <span style="color: #E74C3C;">⏳ Pendiente</span>
                  )}
                </span>
                {gasto.categoria && (
                  <>
                    <span>·</span>
                    <span>{gasto.categoria}</span>
                  </>
                )}
              </div>
            </div>
            
            <!-- Expand indicator -->
            <span 
              class="material-symbols-rounded text-sm flex-shrink-0 transition-transform duration-200"
              :style="`transform: rotate(${isExpanded(gasto.id) ? '180deg' : '0deg'});`"
              style="color: var(--color-text-muted);"
            >
              expand_more
            </span>
          </div>
        </div>
        
        <!-- Detalle expandido -->
        <div 
          x-show="isExpanded(gasto.id)"
          x-collapse.duration.250ms
          class="px-4 py-3 mt-1 rounded-xl"
          style="background: var(--color-event-expanded-bg); border-left: 3px solid var(--color-primary);"
        >
          <div class="space-y-2 text-sm">
            {gasto.incluidoEn && (
              <div>
                <span class="text-xs" style="color: var(--color-text-muted);">Incluido en</span>
                <p style="color: var(--color-text-primary);">{gasto.incluidoEn}</p>
              </div>
            )}
            {gasto.moneda && (
              <div>
                <span class="text-xs" style="color: var(--color-text-muted);">Moneda original</span>
                <p style="color: var(--color-text-primary);">{gasto.moneda}</p>
              </div>
            )}
            <div class="pt-2 border-t" style="border-color: var(--color-border-light);">
              <span class="text-xs" style="color: var(--color-text-muted);">ID</span>
              <p class="text-xs font-mono" style="color: var(--color-text-secondary);">{gasto.id}</p>
            </div>
          </div>
        </div>
      </div>
    </template>
  </div>

  <!-- Sin gastos -->
  <div x-show="gastos.length === 0" class="empty-state py-8">
    <span class="material-symbols-rounded" style="font-size: 32px; opacity: 0.5;">receipt</span>
    <p class="text-sm mt-2" style="color: var(--color-text-secondary);">No hay gastos registrados</p>
  </div>
</div>