---
export interface Evento {
  id: string;
  tipo: string;
  modo?: string;
  nombre: string;
  hora: string;
  direccion?: string;
  detalles?: string;
  icono: string;
  tiempo_estimado?: string;
  reserva?: string;
  compania?: string;
}

const { evento } = Astro.props;

const esArista = evento.tipo === "arista";
---

<div
  class="event-item"
  class:list={["event-item", esArista ? "is-edge" : ""]}
  x-data="{ expanded: false }"
>
  <div class="event-row" @click="expanded = !expanded">
    <span class="event-icon material-symbols-outlined">{evento.icono}</span>
    <span class="event-name">{evento.nombre}</span>
    <span class="event-time">{evento.hora}</span>
    <span
      class="material-symbols-outlined"
      x-text="expanded ? 'expand_less' : 'expand_more'"
    ></span>
  </div>

  <!-- Contenido expandido -->
  <div class="event-details" x-show="expanded" x-collapse.duration.200ms>
    <div class="details-grid">
      {
        evento.direccion && (
          <div class="detail-item">
            <span class="detail-label">Ubicacion</span>
            <span class="detail-value">{evento.direccion}</span>
          </div>
        )
      }

      {
        evento.detalles && (
          <div class="detail-item">
            <span class="detail-label">Detalles</span>
            <span class="detail-value">{evento.detalles}</span>
          </div>
        )
      }

      {
        evento.tiempo_estimado && (
          <div class="detail-item">
            <span class="detail-label">Tiempo estimado</span>
            <span class="detail-value">{evento.tiempo_estimado}</span>
          </div>
        )
      }

      {
        evento.reserva && (
          <div class="detail-item">
            <span class="detail-label">Reserva</span>
            <span class="detail-value">{evento.reserva}</span>
          </div>
        )
      }

      {
        evento.compania && (
          <div class="detail-item">
            <span class="detail-label">Compañia</span>
            <span class="detail-value">{evento.compania}</span>
          </div>
        )
      }
    </div>
  </div>
</div>

<style>
  .event-item {
    padding: 8px 0;
    border-bottom: 1px solid #f0f0f0;
  }

  .event-item:last-child {
    border-bottom: none;
  }

  .event-item.is-edge {
    opacity: 0.85;
    padding-left: 28px;
  }

  .event-item.is-edge .event-icon {
    font-size: 18px;
  }

  .event-row {
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    padding: 4px 0;
  }

  .event-icon {
    font-size: 20px;
    color: #555;
    flex-shrink: 0;
  }

  .event-name {
    flex: 1;
    font-size: 14px;
    color: #222;
  }

  .event-time {
    font-size: 13px;
    color: #888;
    font-weight: 500;
    flex-shrink: 0;
  }

  .event-details {
    padding: 8px 0 4px 34px;
    font-size: 13px;
    color: #444;
  }

  .details-grid {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .detail-item {
    display: flex;
    gap: 8px;
    align-items: baseline;
  }

  .detail-label {
    font-weight: 500;
    color: #888;
    font-size: 12px;
    min-width: 100px;
    flex-shrink: 0;
  }

  .detail-value {
    color: #333;
    font-size: 13px;
  }

  @media (prefers-color-scheme: dark) {
    .event-item {
      border-bottom-color: #3d3d3d;
    }

    .event-icon {
      color: #aaa;
    }

    .event-name {
      color: #ddd;
    }

    .event-time {
      color: #888;
    }

    .event-details {
      color: #bbb;
    }

    .detail-label {
      color: #888;
    }

    .detail-value {
      color: #ccc;
    }
  }
</style>