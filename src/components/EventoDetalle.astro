---
// src/components/EventoDetalle.astro
export interface Props {
  evento: any;
  diaIndex: number;
  colorClass: string;
}

const { evento, diaIndex, colorClass } = Astro.props;
const detalles = evento.detalles || {};
const costo = evento.costo;
// NUEVO: Obtener el orden de visita
const ordenVisita = evento.ordenVisita;
const posicion = evento.posicion;
---

<div class="evento-detalle" class:list={[colorClass]}>
  <!-- Título -->
  <div class="flex items-start justify-between pt-1">
    <div>
      <h3 class="text-base font-semibold" style="color: var(--color-text-primary);">
        <span 
          class="material-symbols-rounded text-xl align-middle mr-1"
          style="color: var(--event-color, var(--color-primary));"
        >
          {evento.icon}
        </span>
        {evento.nombre}
      </h3>
      
      <!-- NUEVO: Mostrar posición en el itinerario de manera prominente -->
      {posicion && (
        <span 
          class="inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded-full mt-1"
          style="background: var(--color-primary); color: white;"
        >
          <span class="material-symbols-rounded text-sm">pin_drop</span>
          <span>Posición {posicion} en el itinerario</span>
        </span>
      )}
      
      {detalles.fecha && (
        <p class="text-sm mt-1" style="color: var(--color-text-secondary);">
          <span class="material-symbols-rounded text-sm align-middle">event</span>
          {new Date(detalles.fecha).toLocaleDateString('es-ES', { 
            weekday: 'long', 
            day: 'numeric', 
            month: 'long', 
            year: 'numeric' 
          })}
          {detalles.horaInicio && (
            <span> · {detalles.horaInicio}</span>
          )}
          {detalles.horaFin && (
            <span> - {detalles.horaFin}</span>
          )}
        </p>
      )}
    </div>
    <button 
      @click="$store.itinerary.toggleEvento(diaIndex, evento.id)"
      class="text-sm p-1 hover:opacity-70 transition-opacity"
      style="color: var(--color-text-muted);"
      aria-label="Cerrar detalles"
    >
      <span class="material-symbols-rounded">close</span>
    </button>
  </div>
  
  <div class="divider"></div>
  
  <!-- NUEVO: Información del orden de visita -->
  <div class="mb-3 p-2 rounded-lg" style="background: var(--color-bg); border: 1px solid var(--color-border-light);">
    <div class="flex items-center justify-between text-xs">
      <span style="color: var(--color-text-muted);">
        <span class="material-symbols-rounded text-sm align-middle">sort</span>
        Orden de visita
      </span>
      <span style="color: var(--color-text-primary);" class="font-medium">
        {ordenVisita !== undefined && ordenVisita >= 0 ? (
          <span>#{ordenVisita + 1} de {evento.totalElementos || '?'}</span>
        ) : (
          <span>No asignado</span>
        )}
      </span>
    </div>
  </div>
  
  <!-- Detalles específicos -->
  <div class="space-y-2 text-sm">
    <!-- Vuelo -->
    {evento.tipo === 'vuelo' && (
      <div class="grid grid-cols-2 gap-1">
        <div>
          <span class="text-xs" style="color: var(--color-text-muted);">Aerolínea</span>
          <p style="color: var(--color-text-primary);">{detalles.aerolinea || 'No especificada'}</p>
        </div>
        <div>
          <span class="text-xs" style="color: var(--color-text-muted);">Número de vuelo</span>
          <p style="color: var(--color-text-primary);">{detalles.numeroVuelo || 'N/A'}</p>
        </div>
        <div>
          <span class="text-xs" style="color: var(--color-text-muted);">Terminal</span>
          <p style="color: var(--color-text-primary);">{detalles.terminal || 'N/A'}</p>
        </div>
        <div>
          <span class="text-xs" style="color: var(--color-text-muted);">Puerta</span>
          <p style="color: var(--color-text-primary);">{detalles.puerta || 'N/A'}</p>
        </div>
        {detalles.codigoReserva && (
          <div class="col-span-2">
            <span class="text-xs" style="color: var(--color-text-muted);">Código de reserva</span>
            <p style="color: var(--color-text-primary);" class="font-mono">{detalles.codigoReserva}</p>
          </div>
        )}
      </div>
    )}
    
    <!-- Hotel -->
    {evento.tipo === 'hotel' && (
      <div>
        {detalles.checkIn && (
          <div class="flex justify-between">
            <span class="text-xs" style="color: var(--color-text-muted);">Check-in</span>
            <span style="color: var(--color-text-primary);">{detalles.checkIn}</span>
          </div>
        )}
        {detalles.checkOut && (
          <div class="flex justify-between">
            <span class="text-xs" style="color: var(--color-text-muted);">Check-out</span>
            <span style="color: var(--color-text-primary);">{detalles.checkOut}</span>
          </div>
        )}
        {detalles.titular && (
          <div class="flex justify-between">
            <span class="text-xs" style="color: var(--color-text-muted);">Titular</span>
            <span style="color: var(--color-text-primary);">{detalles.titular}</span>
          </div>
        )}
        {detalles.plataforma && (
          <div class="flex justify-between">
            <span class="text-xs" style="color: var(--color-text-muted);">Plataforma</span>
            <span style="color: var(--color-text-primary);">{detalles.plataforma}</span>
          </div>
        )}
      </div>
    )}
    
    <!-- Festival -->
    {evento.tipo === 'festival' && (
      <div>
        {detalles.apertura && (
          <div class="flex justify-between">
            <span class="text-xs" style="color: var(--color-text-muted);">Apertura</span>
            <span style="color: var(--color-text-primary);">{detalles.apertura}</span>
          </div>
        )}
        {detalles.cierre && (
          <div class="flex justify-between">
            <span class="text-xs" style="color: var(--color-text-muted);">Cierre</span>
            <span style="color: var(--color-text-primary);">{detalles.cierre}</span>
          </div>
        )}
        {detalles.lineup && detalles.lineup.length > 0 && (
          <div>
            <span class="text-xs" style="color: var(--color-text-muted);">Lineup</span>
            <p style="color: var(--color-text-primary);">{detalles.lineup.join(' · ')}</p>
          </div>
        )}
      </div>
    )}
    
    <!-- Actividad -->
    {evento.tipo === 'actividad' && (
      <div>
        {detalles.duracion && (
          <div class="flex justify-between">
            <span class="text-xs" style="color: var(--color-text-muted);">Duración estimada</span>
            <span style="color: var(--color-text-primary);">{detalles.duracion}</span>
          </div>
        )}
        {detalles.horarioRecomendado && (
          <div class="flex justify-between">
            <span class="text-xs" style="color: var(--color-text-muted);">Horario recomendado</span>
            <span style="color: var(--color-text-primary);">{detalles.horarioRecomendado}</span>
          </div>
        )}
        {detalles.urlOficial && (
          <div>
            <a 
              href={detalles.urlOficial}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm underline hover:opacity-70 transition-opacity"
              style="color: var(--color-primary);"
            >
              <span class="material-symbols-rounded text-sm align-middle">link</span>
              Sitio web oficial
            </a>
          </div>
        )}
      </div>
    )}
    
    <!-- Actividades dentro del nodo -->
    {detalles.actividades && detalles.actividades.length > 0 && (
      <div>
        <span class="text-xs" style="color: var(--color-text-muted);">Actividades planificadas</span>
        <ul class="mt-1 space-y-1">
          {detalles.actividades.map((act: any) => (
            <li key={act.id} class="text-sm flex items-start gap-2" style="color: var(--color-text-primary);">
              <span class="material-symbols-rounded text-sm" style="color: var(--color-text-muted);">check_circle</span>
              <span>
                {act.nombre}
                {act.duracion_estimada && (
                  <span class="text-xs block" style="color: var(--color-text-muted);">{act.duracion_estimada}</span>
                )}
                {act.reserva?.fecha_reservada && (
                  <span class="text-xs block" style="color: var(--color-text-muted);">
                    Reservado: {new Date(act.reserva.fecha_reservada).toLocaleDateString('es-ES')}
                    {act.reserva.hora_reservada && ` a las ${act.reserva.hora_reservada}`}
                  </span>
                )}
              </span>
            </li>
          ))}
        </ul>
      </div>
    )}
    
    <!-- Transporte -->
    {evento.aristaSalida && (
      <div>
        <span class="text-xs" style="color: var(--color-text-muted);">Transporte</span>
        <div class="flex items-center gap-2 mt-1">
          <span 
            class="material-symbols-rounded"
            style="color: var(--event-color, var(--color-primary));"
          >
            {evento.icon}
          </span>
          <span style="color: var(--color-text-primary);">
            {evento.aristaSalida.modo}
            {evento.aristaSalida.transporte?.compania && (
              <span> · {evento.aristaSalida.transporte.compania}</span>
            )}
            {evento.aristaSalida.transporte?.numero_vuelo && (
              <span> · Vuelo {evento.aristaSalida.transporte.numero_vuelo}</span>
            )}
          </span>
        </div>
        {evento.aristaSalida.tiempo_estimado && (
          <div class="text-xs" style="color: var(--color-text-secondary);">
            <span class="material-symbols-rounded text-xs align-middle">schedule</span>
            {evento.aristaSalida.tiempo_estimado.minutos} min
            {evento.aristaSalida.tiempo_estimado.rango && (
              <span> (aprox. {evento.aristaSalida.tiempo_estimado.rango} min)</span>
            )}
          </div>
        )}
        {evento.aristaSalida.transporte?.terminal_origen && (
          <div class="text-xs" style="color: var(--color-text-secondary);">
            <span class="material-symbols-rounded text-xs align-middle">terminal</span>
            Terminal origen: {evento.aristaSalida.transporte.terminal_origen}
            {evento.aristaSalida.transporte.terminal_destino && (
              <span> → Terminal destino: {evento.aristaSalida.transporte.terminal_destino}</span>
            )}
          </div>
        )}
        {evento.aristaSalida.transporte?.codigo_reserva_confirmacion && (
          <div class="text-xs" style="color: var(--color-text-secondary);">
            <span class="material-symbols-rounded text-xs align-middle">confirmation_number</span>
            Código reserva: {evento.aristaSalida.transporte.codigo_reserva_confirmacion}
          </div>
        )}
      </div>
    )}
    
    <!-- Transporte entrante -->
    {evento.aristaEntrante && !evento.aristaSalida && (
      <div>
        <span class="text-xs" style="color: var(--color-text-muted);">Llegada en</span>
        <div class="flex items-center gap-2 mt-1">
          <span 
            class="material-symbols-rounded"
            style="color: var(--event-color, var(--color-primary));"
          >
            {evento.icon}
          </span>
          <span style="color: var(--color-text-primary);">
            {evento.aristaEntrante.modo}
            {evento.aristaEntrante.transporte?.compania && (
              <span> · {evento.aristaEntrante.transporte.compania}</span>
            )}
          </span>
        </div>
      </div>
    )}
  </div>
  
  <!-- Dirección -->
  {evento.direccion && (
    <div class="mt-3">
      <span class="text-xs" style="color: var(--color-text-muted);">Dirección</span>
      <p class="text-sm mt-1" style="color: var(--color-text-primary);">{evento.direccion}</p>
      {evento.mapsLink && (
        <a 
          href={evento.mapsLink}
          target="_blank"
          rel="noopener noreferrer"
          class="maps-link mt-1 inline-flex"
        >
          <span class="material-symbols-rounded text-sm">map</span>
          Ver en Google Maps
        </a>
      )}
    </div>
  )}
  
  <!-- Costos -->
  {costo && (
    <div class="mt-3 pt-2 border-t" style="border-color: var(--color-border-light);">
      <span class="text-xs" style="color: var(--color-text-muted);">Costo</span>
      <div class="flex items-center justify-between mt-1">
        <span style="color: var(--color-text-primary);">
          {$store.itinerary.formatearMonto(costo.valor, costo.moneda)}
          {costo.moneda && (
            <span class="text-xs" style="color: var(--color-text-muted);"> ({costo.moneda})</span>
          )}
        </span>
        <span class="text-xs" style="color: var(--color-text-secondary);">
          {costo.pagado_por ? (
            <>✅ Pagado por {costo.pagado_por}</>
          ) : (
            <>⏳ Pendiente de pago</>
          )}
          {costo.incluido_en && (
            <span class="block text-xs" style="color: var(--color-text-muted);">Incluido en: {costo.incluido_en}</span>
          )}
        </span>
      </div>
    </div>
  )}
  
  <!-- Notas -->
  {detalles.notas && (
    <div class="mt-3 pt-2 border-t" style="border-color: var(--color-border-light);">
      <span class="text-xs" style="color: var(--color-text-muted);">Notas</span>
      <p class="text-sm mt-1" style="color: var(--color-text-secondary);">{detalles.notas}</p>
    </div>
  )}
</div>