{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    // Configuración base de Astro
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@pages/*": ["src/pages/*"],
      "@stores/*": ["src/stores/*"],
      "@styles/*": ["src/styles/*"],
      "@utils/*": ["src/utils/*"]
    },
    
    // Mejores prácticas
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    
    // Módulos
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "allowJs": true,
    
    // Decoradores y JSX
    "experimentalDecorators": true,
    "jsx": "react-jsx",
    "jsxImportSource": "astro",
    
    // Emisión
    "noEmit": true,
    
    // Interoperabilidad
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    
    // Bibliotecas
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ES2022",
    "skipLibCheck": true
  },
  
  // Archivos a incluir
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.js",
    "src/**/*.jsx",
    "src/**/*.astro",
    "astro.config.mjs",
    "tailwind.config.mjs"
  ],
  
  // Archivos a excluir
  "exclude": [
    "node_modules",
    "dist",
    ".astro",
    "public/**/*"
  ]
}